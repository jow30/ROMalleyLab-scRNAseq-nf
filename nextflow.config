/*
 * snRNAseq Processing Pipeline Configuration
 * ============================================
 */

// ── Pipeline parameters ─────────────────────────────────────────────────────

params {
    // ── Mandatory ──
    input   = null          // Path to input samplesheet CSV
    out     = null          // Output directory
    species = 'Arabidopsis thaliana'  // Species name(s), comma-separated for multi-species

    // ── Reference paths (auto-resolved from species if not provided) ──
    ref_yaml = "${projectDir}/refs/scQC.yaml"

    // ── Filtering parameters (universal, passed to preprocess.R) ──
    min_diem_debris_score = 1
    min_unsplice_ratio    = 0.1
    min_nCount_RNA        = 400
    min_nFeature_RNA      = 300
    max_mt                = 10
    max_cp                = 15
    nHVG                  = 3000
    min_ncell_expr        = 5
    remove_doublet        = true
    max_doublet_score     = 0.4
    min_nClusterMarker    = 5
    min_cells             = 500

    // ── Filtering parameters (demultiplexing, passed to demultiplex.R) ──
    clean                       = null   // 'diem' or 'chi'; auto-selected if null
    min_UMI_per_cell_barcode    = 400
    chisq_pvalues_max           = 0.01
    ambient_rate_max            = 0.5
    multiple_species_per_droplet = true

    // ── Read counting ──
    bin_size = 2000

    // ── Integration ──
    nFeatures = 3000

    // ── Cleanup ──
    cleanup = false

    // ── Help ──
    help = false
}

// ── Species reference maps (overridden by institution profile) ──────────────
// Default to empty so the pipeline runs portably from GitHub. Institution
// profiles (e.g. `uchicago_midway`) or a user-supplied `-c my.config` should
// populate these with site-specific paths.
//
// Expected shape:
//   params.species_map = [
//       '<species name>': [genome: '...', gtf: '...', cellranger: '...'],
//       ...
//   ]
//   params.combined_ref_map = [
//       '<sorted,comma,separated,species>': '<path/to/combined/cellranger>',
//       ...
//   ]
params.species_map      = [:]
params.combined_ref_map = [:]

// ── Load process configuration ──────────────────────────────────────────────

includeConfig 'conf/base.config'

// ── Execution profiles ──────────────────────────────────────────────────────

profiles {
    // Default profile: UChicago Midway-3 (Slurm executor, module envs, project
    // paths, and species/combined reference maps). Tied to the gzy8899 project
    // tree. External users should pass `-profile local` and supply their own
    // reference paths via `-c my.config`.
    standard {
        includeConfig 'conf/slurm.config'
        includeConfig 'conf/refs.config'
    }

    // Explicit alias of `standard` for clarity in command lines / docs.
    uchicago_midway {
        includeConfig 'conf/slurm.config'
        includeConfig 'conf/refs.config'
    }

    // Portable local execution, no institution paths or modules.
    local {
        process.executor = 'local'
    }
}

manifest {
    name            = 'snRNAseq-pipeline'
    author          = 'Qiaoshan Lin'
    description     = 'snRNAseq data processing pipeline for plants'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
