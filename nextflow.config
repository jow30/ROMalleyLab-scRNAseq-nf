/*
 * snRNAseq Processing Pipeline Configuration
 * ============================================
 */

// ── Pipeline parameters ─────────────────────────────────────────────────────

params {
    // ── Mandatory ──
    input   = null          // Path to input samplesheet CSV
    out     = null          // Output directory
    species = 'Arabidopsis thaliana'  // Species name(s), comma-separated for multi-species

    // ── Reference paths (auto-resolved from species if not provided) ──
    genome   = null         // Path(s) to genome FASTA file(s)
    gtf      = null         // Path(s) to GTF file(s)
    ref_yaml = "${projectDir}/refs/scQC.yaml"

    // ── Filtering parameters (universal, passed to preprocess.R) ──
    min_diem_debris_score = 1
    min_unsplice_ratio    = 0.1
    min_nCount_RNA        = 400
    min_nFeature_RNA      = 300
    max_mt                = 10
    max_cp                = 15
    nHVG                  = 3000
    min_ncell_expr        = 5
    remove_doublet        = true
    max_doublet_score     = 0.4
    min_nClusterMarker    = 5

    // ── Filtering parameters (demultiplexing, passed to demultiplex.R) ──
    clean                       = null   // 'diem' or 'chi'; auto-selected if null
    min_UMI_per_cell_barcode    = 400
    chisq_pvalues_max           = 0.01
    ambient_rate_max            = 0.5
    multiple_species_per_droplet = true

    // ── Read counting ──
    bin_size = 2000

    // ── Integration ──
    nFeatures = 3000

    // ── Cleanup ──
    cleanup = false

    // ── Help ──
    help = false
}

// ── Species reference map ───────────────────────────────────────────────────
// Maps species names to their reference files.
// Add new species here with genome, gtf, cellranger, seurat_ref, and optional markers.

params.species_map = [
    'Arabidopsis thaliana': [
        genome:      '/project/gzy8899/references/Arabidopsis_thaliana/Phytozome/PhytozomeV12/early_release/Athaliana_447_Araport11/assembly/Athaliana_447_TAIR10.fa',
        gtf:         '/project/gzy8899/qiaoshan/scRNAseq/references/Arabidopsis_thaliana/Athaliana_447_Araport11.gene.gtf',
        cellranger:  "${projectDir}/refs/Arabidopsis_thaliana/cellranger",
        seurat_ref:  '/project/gzy8899/qiaoshan/scRNAseq/references/Arabidopsis_thaliana/GSE297576_seurat_object.thaliana_seedling_atlas.RDS',
        markers:     '/project/gzy8899/qiaoshan/scRNAseq/references/Arabidopsis_thaliana/markers/arabidopsis_thaliana.marker_fd.csv'
    ],
    'Arabidopsis lyrata': [
        genome:      '/project/gzy8899/references/Arabidopsis_lyrata/Phytozome/Alyrata_384_v2.1/assembly/Alyrata_384_v1.fa',
        gtf:         '/project/gzy8899/qiaoshan/scRNAseq/references/Arabidopsis_lyrata/Alyrata_384_v2.1.gene.gtf',
        cellranger:  "${projectDir}/refs/Arabidopsis_lyrata/cellranger",
        seurat_ref:  '/project/gzy8899/qiaoshan/scRNAseq/references/Arabidopsis_lyrata/GSE297576_seurat_object.lyrata_seedling_atlas.RDS',
        markers:     null
    ],
    'Capsella rubella': [
        genome:      '/project/gzy8899/references/Capsella_rubella/Phytozome/Crubella_474_v1.fa',
        gtf:         '/project/gzy8899/qiaoshan/scRNAseq/references/Capsella_rubella/Crubella_474_v1.1.gene.gtf',
        cellranger:  "${projectDir}/refs/Capsella_rubella/cellranger",
        seurat_ref:  '/project/gzy8899/qiaoshan/scRNAseq/references/Capsella_rubella/GSE297576_seurat_object.rubella_seedling_atlas.RDS',
        markers:     null
    ],
    'Brassica oleracea': [
        genome:      '/project/gzy8899/references/Brassica_oleracea/Phytozome/Boleraceacapitata_446_v1.0/assembly/Boleraceacapitata_446_v1.0.fa',
        gtf:         '/project/gzy8899/qiaoshan/scRNAseq/references/Brassica_oleracea/Boleraceacapitata_446_v1.0.gene.gtf',
        cellranger:  "${projectDir}/refs/Brassica_oleracea/cellranger",
        seurat_ref:  '/project/gzy8899/qiaoshan/scRNAseq/references/Brassica_oleracea/GSE297576_seurat_object.oleracea_seedling_atlas.RDS',
        markers:     null
    ]
]

// ── Combined-species cellranger reference map ───────────────────────────────
// Maps sorted comma-separated species names to pre-built combined references.
params.combined_ref_map = [
    'Arabidopsis thaliana,Capsella rubella': "${projectDir}/refs/Athaliana_Crubella/cellranger",
    'Arabidopsis lyrata,Arabidopsis thaliana,Brassica oleracea,Capsella rubella': "${projectDir}/refs/Athaliana_Alyrata_Crubella_Boleracea/cellranger"
]

// ── Load process configuration ──────────────────────────────────────────────

includeConfig 'conf/base.config'
includeConfig 'conf/slurm.config'

// ── Execution profiles ──────────────────────────────────────────────────────

profiles {
    standard {
        process.executor = 'slurm'
    }
    local {
        process.executor = 'local'
    }
}

manifest {
    name            = 'snRNAseq-pipeline'
    author          = 'Qiaoshan Lin'
    description     = 'snRNAseq data processing pipeline for plants'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
