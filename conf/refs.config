/*
 * Institution-specific reference paths
 * ====================================
 * Per-species genome / GTF / cellranger reference locations on the UChicago
 * Midway-3 cluster (project gzy8899). Paths in this file are NOT portable.
 *
 * External users should provide their own equivalent file via `-c my.config`
 * or by enabling a different institution profile in `nextflow.config`.
 */

params.species_map = [
