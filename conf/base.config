/*
 * Base process configuration: resource requirements (defaults / local profile)
 */

process {
    cache = 'lenient'

    withLabel: 'process_low' {
        cpus   = 4
        memory = '8 GB'
        time   = '2h'
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '16 GB'
        time   = '6h'
    }
    withLabel: 'process_high' {
        cpus   = 16
        memory = '24 GB'
        time   = '12h'
    }
    withLabel: 'process_cellranger' {
        cpus   = 32
        memory = '16 GB'
        time   = '12h'
    }

    // summary.Rmd: avoid OOM (same issue as Slurm override below)
    withName: 'SUMMARY_REPORT' {
        cpus   = 1
        memory = '48 GB'
        time   = '2h'
    }

    // DIEM_DEBRIS_REMOVAL: diem::run_em() scales superlinearly with the size
    // of the debris pool, which gets very large for the minor species in a
    // multi-species sample. Mirror the slurm.config override so the local
    // profile also gets a generous time budget and an OOM/timeout retry.
    withName: 'DIEM_DEBRIS_REMOVAL' {
        cpus          = 8
        memory        = { 16.GB * task.attempt }
        time          = { 12.h  * task.attempt }
        errorStrategy = { task.exitStatus in [137, 140, 143] ? 'retry' : 'terminate' }
        maxRetries    = 2
    }
}
