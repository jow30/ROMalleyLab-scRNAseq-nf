/*
 * Slurm HPC configuration: executor settings, module environments,
 * and resource requirements.
 *
 * Resources here override base.config values for the Slurm profile.
 * Adjust cpus / memory / time to match your cluster partition limits.
 */

process {
    executor       = 'slurm'
    clusterOptions = '--account=pi-gzy8899'
    queue          = 'caslake'

    // ── Resource requirements ─────────────────────────────────────────────────
    withLabel: 'process_low' {
        cpus   = 4
        memory = '8 GB'
        time   = '2h'
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '32 GB'
        time   = '6h'
    }
    withLabel: 'process_high' {
        cpus   = 16
        memory = '64 GB'
        time   = '12h'
    }
    withLabel: 'process_cellranger' {
        cpus   = 32
        memory = '16 GB'
        time   = '12h'
    }

    // ── Module environments ───────────────────────────────────────────────────
    withLabel: 'cellranger' {
        beforeScript = 'module load cellranger/9.0.1'
    }
    withLabel: 'scrnaseq' {
        beforeScript = 'module load scrnaseq/1.0'
    }
    withLabel: 'velocyto' {
        beforeScript = 'module load velocyto/0.17.17; module load samtools/1.22.1'
    }
    withLabel: 'samtools' {
        beforeScript = 'module load samtools/1.22.1'
    }
    withLabel: 'deeptools' {
        beforeScript = 'module load samtools/1.22.1; module load deeptools/3.5.6'
    }

    withName: 'SUMMARY_REPORT' {
        cpus = 1
        memory = '64 GB'
        time   = '2h'
    }

    // DIEM_DEBRIS_REMOVAL: in multi-species samples the minor-species DIEM
    // run sees a heavily imbalanced test/debris partition (most barcodes
    // become 'debris'), so diem::run_em() can take many hours on large raw
    // matrices. Give it a much longer wallclock than the generic 'process_medium'
    // 6h budget, and auto-retry with doubled time on signal-induced kills:
    //   137 = SIGKILL (typically OOM or hard kill)
    //   140 = 128 + 12 = SIGUSR2 (Slurm grace signal at time-limit)
    //   143 = SIGTERM (Slurm soft kill)
    withName: 'DIEM_DEBRIS_REMOVAL' {
        cpus          = 8
        memory        = { 32.GB * task.attempt }
        time          = { 12.h  * task.attempt }
        errorStrategy = { task.exitStatus in [137, 140, 143] ? 'retry' : 'terminate' }
        maxRetries    = 2
    }
}
